# Python / PyInstaller Output
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
env/
venv/

# PyInstaller / Build Artifacts
/build/
/dist/
*.manifest
*.spec

# ==========================================
# Poetry / Packaging (if applicable)
# ==========================================
.poetry/
poetry.lock

